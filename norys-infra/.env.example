# ============================================================
# Norys stack — global environment
# Copy to .env and fill in. This file is shared by docker-compose
# and passed into the api container (env_file: .env).
# ============================================================

# --- Edge / domain ---
# Use "localhost" for local testing, or your real domain for production TLS.
NORYS_DOMAIN=localhost
# Email used by Caddy for Let's Encrypt (ignored on localhost).
NORYS_TLS_EMAIL=admin@example.com

# --- App ---
NORYS_ENV=production
NORYS_DEBUG=false
NORYS_PROJECT_NAME=Norys
NORYS_API_PREFIX=/api/v1
# CORS not strictly needed (same-origin via proxy) but kept for API clients.
NORYS_CORS_ORIGINS=https://localhost

# --- Security ---
# REQUIRED. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
NORYS_SECRET_KEY=
NORYS_ACCESS_TOKEN_EXPIRE_MINUTES=30
NORYS_REFRESH_TOKEN_EXPIRE_DAYS=14

# --- PostgreSQL ---
NORYS_POSTGRES_USER=norys
# REQUIRED. Use a strong password.
NORYS_POSTGRES_PASSWORD=
NORYS_POSTGRES_DB=norys

# --- Redis ---
# Optional but recommended in production.
NORYS_REDIS_PASSWORD=

# ============================================================
# LLM providers
# ============================================================

# Default provider: "ollama" (local, no internet), "openai", or "openrouter"
NORYS_DEFAULT_LLM_PROVIDER=ollama
NORYS_DEFAULT_LLM_MODEL=llama3.1

# OpenAI (leave empty if not using)
NORYS_OPENAI_API_KEY=
NORYS_OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter (leave empty if not using)
NORYS_OPENROUTER_API_KEY=
NORYS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama URL — set automatically by docker-compose (http://ollama:11434)
# Override only if Ollama runs on a separate host.
NORYS_OLLAMA_BASE_URL=http://ollama:11434

# ============================================================
# RAG / Vector store (Qdrant)
# ============================================================

# Qdrant URL — set automatically by docker-compose (http://qdrant:6333)
NORYS_QDRANT_URL=http://qdrant:6333
# Qdrant API key (leave empty if Qdrant auth is disabled)
NORYS_QDRANT_API_KEY=

# Embedding provider and model
# Ollama (fully local, recommended): nomic-embed-text → dim 768
# OpenAI: text-embedding-3-small → dim 1536
NORYS_EMBEDDING_PROVIDER=ollama
NORYS_EMBEDDING_MODEL=nomic-embed-text
NORYS_EMBEDDING_DIM=768

# Document chunking
NORYS_CHUNK_SIZE=800
NORYS_CHUNK_OVERLAP=100
