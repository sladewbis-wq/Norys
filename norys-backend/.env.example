# ============================================================
# Norys Core — environment configuration
# Copy to .env and adjust. NEVER commit your real .env.
# ============================================================

# --- App ---
NORYS_ENV=development                 # development | staging | production
NORYS_DEBUG=true
NORYS_API_PREFIX=/api/v1
NORYS_PROJECT_NAME=Norys

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
NORYS_SECRET_KEY=change-me-please-use-a-long-random-string
NORYS_ACCESS_TOKEN_EXPIRE_MINUTES=30
NORYS_REFRESH_TOKEN_EXPIRE_DAYS=14
NORYS_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# --- PostgreSQL ---
NORYS_POSTGRES_HOST=localhost
NORYS_POSTGRES_PORT=5432
NORYS_POSTGRES_USER=norys
NORYS_POSTGRES_PASSWORD=norys
NORYS_POSTGRES_DB=norys

# --- Redis ---
NORYS_REDIS_HOST=localhost
NORYS_REDIS_PORT=6379
NORYS_REDIS_DB=0
NORYS_REDIS_PASSWORD=

# --- LLM providers (all optional; configure what you use) ---
# Default provider used when an agent does not specify one: openai | openrouter | ollama
NORYS_DEFAULT_LLM_PROVIDER=ollama
NORYS_DEFAULT_LLM_MODEL=llama3.1

# OpenAI
NORYS_OPENAI_API_KEY=
NORYS_OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter
NORYS_OPENROUTER_API_KEY=
NORYS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama (local, self-hosted)
NORYS_OLLAMA_BASE_URL=http://localhost:11434
